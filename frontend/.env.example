# =============================================================================
# Logitrak — Frontend (Expo) · Variables de entorno
# -----------------------------------------------------------------------------
# Copiá este archivo a ".env" y completá los valores.
#   Windows PowerShell:  copy .env.example .env
#   Linux / macOS:       cp .env.example .env
#
# IMPORTANTE: en Expo, TODA variable que el cliente necesite leer debe empezar
# con el prefijo EXPO_PUBLIC_. Estas variables quedan embebidas en el bundle,
# así que NO pongas acá secretos del servidor (eso va en el backend).
#
# Para los builds en la nube (EAS Build) estas variables NO se leen de este
# archivo: hay que cargarlas en EAS con `eas env:create` o desde el dashboard
# del proyecto. Este .env solo aplica cuando corrés en local con `expo start`.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) BACKEND  <-- COMPLETAR (obligatorio)
# -----------------------------------------------------------------------------
# URL del backend que consume la app.
#
# Producción (recomendado, anda desde cualquier red, web, emulador e iPhone):
#   apuntá a la URL pública del backend en Render.
EXPO_PUBLIC_API_URL=https://logitrak.onrender.com
#
# Desarrollo local contra tu propio backend (`npm run dev` en /backend):
#   usá la IP LAN de tu PC (NO "localhost", el celular no lo resuelve).
#   El puerto :4000 se mantiene. Ej:
# EXPO_PUBLIC_API_URL=http://aqui-va-tu-ip:4000

# -----------------------------------------------------------------------------
# 2) GOOGLE MAPS  <-- COMPLETAR (obligatorio para que anden los mapas)
# -----------------------------------------------------------------------------
# Claves de la Google Cloud Console (APIs: Maps SDK for Android, Directions,
# Maps JavaScript para web). Restringí cada clave por package name + SHA-1
# para que no las pueda usar cualquiera, ya que quedan embebidas en la app.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=your_android_maps_key_here
EXPO_PUBLIC_GOOGLE_DIRECTIONS_KEY=your_directions_key_here
EXPO_PUBLIC_GOOGLE_MAPS_WEB_KEY=your_web_maps_key_here
