# =============================================================================
# Logitrak — Backend · Variables de entorno
# -----------------------------------------------------------------------------
# Copiá este archivo a ".env" y completá los valores marcados con  <-- COMPLETAR.
#   Windows PowerShell:  copy .env.example .env
#   Linux / macOS:       cp .env.example .env
# Solo hacen falta DOS cosas para arrancar: DATABASE_URL y JWT_SECRET.
# El resto es opcional: sin esas claves, el sistema corre en modo demo/sandbox.
# =============================================================================

# Puerto donde queda la API (la app del frontend la consume acá).
PORT=4000

# -----------------------------------------------------------------------------
# 1) BASE DE DATOS (Supabase)  <-- COMPLETAR (obligatorio)
# -----------------------------------------------------------------------------
# Cómo obtener el valor:
#   1. Entrá al proyecto en https://supabase.com
#   2. Botón "Connect" (arriba) -> pestaña "Connection string"
#   3. Elegí "Session pooler" y tipo "URI"
#   4. Copiá el texto y reemplazá [YOUR-PASSWORD] por la contraseña de la base
# Queda algo así (los corchetes NO van, son solo el marcador):
DATABASE_URL=postgresql://postgres.tu-ref:tu-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# 2) AUTENTICACIÓN  <-- COMPLETAR (obligatorio)
# -----------------------------------------------------------------------------
# Clave secreta para firmar los tokens de sesión (JWT). Generá una propia con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=pega_aqui_tu_clave_generada
JWT_EXPIRA=8h

# -----------------------------------------------------------------------------
# 3) OPCIONALES — dejalos vacíos para probar el sistema
# -----------------------------------------------------------------------------
# Si quedan en blanco, todo funciona igual en modo demo:
#   · Verificación de identidad: OFFLINE (lee el código PDF417 del dorso del DNI).
#   · Pagos: el QR cae a un sandbox que se aprueba desde la app y la tarjeta
#     usa un procesador SIMULADO (nunca cobra de verdad).
RENAPER_API_URL=
RENAPER_API_KEY=
MP_ACCESS_TOKEN=
MODO_API_URL=
MODO_CLIENT_ID=
MODO_CLIENT_SECRET=
